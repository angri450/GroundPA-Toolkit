    "Heading1": { "fontCJK": "黑体", "fontSize": "28", "bold": true, "alignment": "left" },
    "Heading2": { "fontCJK": "黑体", "fontSize": "24", "bold": true, "alignment": "left" },
    "Body": { "fontCJK": "宋体", "fontLatin": "Times New Roman", "fontSize": "21", "firstLineIndent": "420", "lineSpacing": "312" },
    "Abstract": { "fontCJK": "宋体", "fontSize": "18", "firstLineIndent": "420" },
    "AbstractTitle": { "fontCJK": "黑体", "fontSize": "18", "bold": true },
